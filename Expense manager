@Composable
fun MetricsRow(analytics: DashboardAnalytics, project: ProjectEntity?) {
    Column(verticalArrangement = Arrangement.spacedBy(8.dp)) {
        Row(horizontalArrangement = Arrangement.spacedBy(8.dp), modifier = Modifier.fillMaxWidth()) {
            MetricCard("Planned", formatMoney(analytics.planned, project), Modifier.weight(1f))
            MetricCard("Actual", formatMoney(analytics.actual, project), Modifier.weight(1f))
        }
        Row(horizontalArrangement = Arrangement.spacedBy(8.dp), modifier = Modifier.fillMaxWidth()) {
            MetricCard("Variance", formatMoney(analytics.variance, project), Modifier.weight(1f))
            MetricCard("Progress", "${analytics.progress}%", Modifier.weight(1f))
        }
        MetricCard("Forecast Completion Cost", formatMoney(analytics.forecastCompletionCost, project), Modifier.fillMaxWidth())
    }
}

@Composable
fun MetricCard(label: String, value: String, modifier: Modifier = Modifier) {
    Card(modifier = modifier, shape = RoundedCornerShape(20.dp)) {
        Column(Modifier.padding(16.dp)) {
            Text(label, color = Color.Gray)
            Text(value, fontWeight = FontWeight.Bold, style = MaterialTheme.typography.titleLarge)
        }
    }
}


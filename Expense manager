@Composable
fun ConstructionApp(viewModel: ConstructionViewModel = androidx.lifecycle.viewmodel.compose.viewModel()) {
    val state by viewModel.uiState.collectAsState()
    val context = androidx.compose.ui.platform.LocalContext.current

    val importLauncher = rememberLauncherForActivityResult(ActivityResultContracts.OpenDocument()) { uri ->
        uri?.let { context.contentResolver.openInputStream(it)?.use { input -> viewModel.importExcel(state.project?.id ?: 1L, input) } }
    }

    val exportLauncher = rememberLauncherForActivityResult(ActivityResultContracts.CreateDocument("application/vnd.openxmlformats-officedocument.spreadsheetml.sheet")) { uri ->
        uri?.let { context.contentResolver.openOutputStream(it)?.use { output -> viewModel.exportExcel(output, state) } }
    }

    val photoLauncher = rememberLauncherForActivityResult(ActivityResultContracts.OpenMultipleDocuments()) { uris ->
        uris.forEach { viewModel.addDocument(state.phases.firstOrNull()?.id ?: 1L, null, "PHOTO", it) }
    }

    val invoiceLauncher = rememberLauncherForActivityResult(ActivityResultContracts.OpenMultipleDocuments()) { uris ->
        uris.forEach { viewModel.addDocument(state.phases.firstOrNull()?.id ?: 1L, null, "INVOICE", it) }
    }

    LazyColumn(modifier = Modifier.fillMaxSize().background(Color(0xFFF1F5F9)).padding(16.dp), verticalArrangement = Arrangement.spacedBy(16.dp)) {
        item { Header() }
        item { MetricsRow(state.analytics, state.project) }
        item { ExcelActions(onImport = { importLauncher.launch(arrayOf("application/vnd.openxmlformats-officedocument.spreadsheetml.sheet")) }, onExport = { exportLauncher.launch("construction_reports.xlsx") }) }
        item { ForecastWarnings(state.analytics) }
        item { PhaseCostChart(state.phases, state.expenses, state.project) }
        item { PhaseProgressList(state.phases, state.expenses, state.project, onProgress = viewModel::updateProgress) }
        item { GanttChart(state.phases) }
        item { ContractorCrud(state.contractors, onAdd = viewModel::addContractor, onDelete = viewModel::deleteContractor) }
        item { ExpenseEntry(state.phases, state.contractors, onAdd = viewModel::addExpense) }
        item { DocumentButtons(onPhoto = { photoLauncher.launch(arrayOf("image/*")) }, onInvoice = { invoiceLauncher.launch(arrayOf("application/pdf", "image/*")) }) }
        item { DocumentList(state.documents) }
    }
}


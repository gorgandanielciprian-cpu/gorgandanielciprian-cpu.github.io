@Composable
fun ForecastWarnings(analytics: DashboardAnalytics) {
    Card(shape = RoundedCornerShape(20.dp)) {
        Column(Modifier.padding(16.dp)) {
            Text("AI Forecasting & Budget Warnings", fontWeight = FontWeight.Bold)

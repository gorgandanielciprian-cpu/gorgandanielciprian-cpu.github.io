data class DashboardAnalytics(
    val planned: Double = 0.0,
    val actual: Double = 0.0,
    val variance: Double = 0.0,
    val variancePct: Int = 0,
    val progress: Int = 0,
    val forecastCompletionCost: Double = 0.0,
    val forecastVariance: Double = 0.0,
    val vatExposure: Double = 0.0,
    val warnings: List<String> = emptyList()
)

private fun phaseActualCost(phase: ConstructionPhaseEntity, expenses: List<ExpenseEntity>): Double {
    return phase.actualCost + expenses.filter { it.phaseId == phase.id }.sumOf { it.amount }
}
fun calculateAnalytics(project: ProjectEntity?, phases: List<ConstructionPhaseEntity>, expenses: List<ExpenseEntity>): DashboardAnalytics {
    val planned = phases.sumOf { it.plannedCost }
    val actual = phases.sumOf { phaseActualCost(it, expenses) }
    val variance = planned - actual
    val variancePct = if (planned > 0) ((variance / planned) * 100).roundToInt() else 0
    val progress = if (planned > 0) (phases.sumOf { it.progress * it.plannedCost } / planned).roundToInt() else 0
    val remainingWorkPct = ((100 - progress).coerceAtLeast(0)) / 100.0
    val forecast = actual + planned * remainingWorkPct
    val forecastVariance = planned - forecast
    val vatRate = project?.vatRate ?: 0.19
    val vat = expenses.sumOf { if (it.vatIncluded) it.amount * vatRate / (1 + vatRate) else it.amount * vatRate }
    val warnings = buildList {
        if (forecastVariance < 0) add("Forecast overrun risk: ${(forecastVariance * -1).roundToInt()}")
        if (variancePct < 10) add("Remaining budget buffer is below 10%")
        if (phases.any { phaseActualCost(it, expenses) > it.plannedCost }) add("One or more construction phases exceed budget")
    }

    return DashboardAnalytics(planned, actual, variance, variancePct, progress, forecast, forecastVariance, vat, warnings)
}

fun convertCurrency(amountEur: Double, currency: String, rate: Double): Double = if (currency == "RON") amountEur * rate else amountEur

fun formatMoney(amountEur: Double, project: ProjectEntity?): String {
    val currency = project?.baseCurrency ?: "EUR"
    val rate = project?.exchangeRateRonPerEur ?: 5.05
    return "$currency ${convertCurrency(amountEur, currency, rate).roundToInt()}"
}

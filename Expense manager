@Entity(tableName = "projects")
data class ProjectEntity(
    @PrimaryKey(autoGenerate = true) val id: Long = 0,
    val name: String,
    val location: String,
    val baseCurrency: String = "EUR",
    val exchangeRateRonPerEur: Double = 5.05,
    val vatRate: Double = 0.19
)

@Entity(
    tableName = "construction_phases",
    foreignKeys = [ForeignKey(entity = ProjectEntity::class, parentColumns = ["id"], childColumns = ["projectId"], onDelete = ForeignKey.CASCADE)],
    indices = [Index("projectId"), Index(value = ["projectId", "name"], unique = true)]
)
data class ConstructionPhaseEntity(
    @PrimaryKey(autoGenerate = true) val id: Long = 0,
    val projectId: Long,
    val name: String,
    val plannedCost: Double,
    val actualCost: Double,
    val progress: Int,
    val startDate: String,
    val endDate: String,

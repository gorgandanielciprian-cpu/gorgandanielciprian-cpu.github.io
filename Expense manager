class ConstructionExcelService(private val dao: ConstructionDao) {
    private val formatter = DataFormatter()


    suspend fun importWorkbook(projectId: Long, inputStream: InputStream) = withContext(Dispatchers.IO) {
        val workbook = XSSFWorkbook(inputStream)
        val sheet = workbook.getSheet("Import") ?: workbook.getSheetAt(0)

        for (rowIndex in 1..sheet.lastRowNum) {
            val row = sheet.getRow(rowIndex) ?: continue
            val phaseName = text(row.getCell(0))
            val task = text(row.getCell(1))
            val contractorName = text(row.getCell(2))
            val planned = number(row.getCell(3))
            val actual = number(row.getCell(4))
            val startDate = dateOrText(row.getCell(5))
            val endDate = dateOrText(row.getCell(6))
            val status = text(row.getCell(7)).ifBlank { "Not Started" }
            if (phaseName.isBlank()) continue

            // Important correction: imported actual cost is stored as an expense, not also as phase.actualCost.
            // This avoids double counting in analytics.
            val phaseId = dao.upsertPhaseByName(
                ConstructionPhaseEntity(
                    projectId = projectId,
                    name = phaseName,
                    plannedCost = planned,
                    actualCost = 0.0,
                    progress = statusToProgress(status),
                    startDate = startDate,
                    endDate = endDate,
                    status = normalizeStatus(status)
                )
            )

            val contractorId = if (contractorName.isNotBlank()) {
                dao.upsertContractorByCompany(ContractorEntity(company = contractorName, contact = "", phone = "", email = "", trade = phaseName))
            } else null
            if (actual > 0) {
                dao.insertExpense(
                    ExpenseEntity(
                        phaseId = phaseId,
                        contractorId = contractorId,
                        category = if (contractorId != null) "Contractors" else "Materials",
                        description = task.ifBlank { "Imported cost for $phaseName" },
                        amount = actual,
                        currency = "EUR",
                        vatIncluded = true,
                        date = startDate
                    )
                )
            }
        }
        workbook.close()
    }

    fun exportReports(project: ProjectEntity?, phases: List<ConstructionPhaseEntity>, contractors: List<ContractorEntity>, expenses: List<ExpenseEntity>, outputStream: OutputStream) {
        val workbook = XSSFWorkbook()

        val budgetSheet = workbook.createSheet("Budget vs Actual")
        budgetSheet.createRow(0).apply {
            createCell(0).setCellValue("Phase")
            createCell(1).setCellValue("Planned Cost")
            createCell(2).setCellValue("Actual Cost")
            createCell(3).setCellValue("Variance")
            createCell(4).setCellValue("Progress")
            createCell(5).setCellValue("Status")
        }
        phases.forEachIndexed { index, phase ->
            val actual = phaseActualCost(phase, expenses)
            budgetSheet.createRow(index + 1).apply {
                createCell(0).setCellValue(phase.name)
                createCell(1).setCellValue(phase.plannedCost)
                createCell(2).setCellValue(actual)
                createCell(3).setCellValue(phase.plannedCost - actual)
                createCell(4).setCellValue(phase.progress.toDouble())
                createCell(5).setCellValue(phase.status)
            }
        }

        val contractorSheet = workbook.createSheet("Contractor Costs")
        contractorSheet.createRow(0).apply {
            createCell(0).setCellValue("Contractor")
            createCell(1).setCellValue("Trade")
            createCell(2).setCellValue("Total Cost")
        }
        contractors.forEachIndexed { index, contractor ->
            val total = expenses.filter { it.contractorId == contractor.id }.sumOf { it.amount }
            contractorSheet.createRow(index + 1).apply {
                createCell(0).setCellValue(contractor.company)
                createCell(1).setCellValue(contractor.trade)
                createCell(2).setCellValue(total)
            }
        }

        val materialSheet = workbook.createSheet("Material Costs")
        materialSheet.createRow(0).apply {
            createCell(0).setCellValue("Description")
            createCell(1).setCellValue("Amount")
            createCell(2).setCellValue("Date")
        }
        expenses.filter { it.category == "Materials" }.forEachIndexed { index, expense ->
            materialSheet.createRow(index + 1).apply {
                createCell(0).setCellValue(expense.description)
                createCell(1).setCellValue(expense.amount)
                createCell(2).setCellValue(expense.date)
            }
        }

        val cashFlowSheet = workbook.createSheet("Monthly Cash Flow")
        cashFlowSheet.createRow(0).apply {
            createCell(0).setCellValue("Month")
            createCell(1).setCellValue("Total Cost")
        }
        expenses.groupBy { it.date.take(7) }.entries.forEachIndexed { index, entry ->
            cashFlowSheet.createRow(index + 1).apply {
                createCell(0).setCellValue(entry.key)
                createCell(1).setCellValue(entry.value.sumOf { it.amount })
            }
        }
        val progressSheet = workbook.createSheet("Project Progress")
        progressSheet.createRow(0).apply {
            createCell(0).setCellValue("Phase")
            createCell(1).setCellValue("Start Date")
            createCell(2).setCellValue("End Date")
            createCell(3).setCellValue("Progress")
            createCell(4).setCellValue("Status")
        }
        phases.forEachIndexed { index, phase ->
            progressSheet.createRow(index + 1).apply {
                createCell(0).setCellValue(phase.name)
                createCell(1).setCellValue(phase.startDate)
                createCell(2).setCellValue(phase.endDate)
                createCell(3).setCellValue(phase.progress.toDouble())
                createCell(4).setCellValue(phase.status)
            }
        }


        repeat(workbook.numberOfSheets) { sheetIndex -> workbook.getSheetAt(sheetIndex).autoSizeColumn(0) }
        workbook.write(outputStream)
        workbook.close()
    }


    private fun text(cell: Cell?): String = cell?.let { formatter.formatCellValue(it).trim() }.orEmpty()


    private fun number(cell: Cell?): Double = when {
        cell == null -> 0.0
        cell.cellType == Cell.CELL_TYPE_NUMERIC -> cell.numericCellValue
        else -> formatter.formatCellValue(cell).replace(",", "").toDoubleOrNull() ?: 0.0
    }


    private fun dateOrText(cell: Cell?): String {
        if (cell == null) return ""
        return if (cell.cellType == Cell.CELL_TYPE_NUMERIC && DateUtil.isCellDateFormatted(cell)) {
            cell.localDateTimeCellValue.toLocalDate().toString()
        } else text(cell)
    }


    private fun normalizeStatus(status: String): String = when (status.trim().lowercase()) {
        "completed", "complete", "done" -> "Completed"
        "in progress", "progress", "ongoing" -> "In Progress"
        else -> "Not Started"
    }


    private fun statusToProgress(status: String): Int = when (normalizeStatus(status)) {
        "Completed" -> 100
        "In Progress" -> 50
        else -> 0
    }
}


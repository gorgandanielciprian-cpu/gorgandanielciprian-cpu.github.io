@Dao
interface ConstructionDao {
    @Query("SELECT * FROM projects LIMIT 1")
    fun observeProject(): Flow<ProjectEntity?>

    @Query("SELECT * FROM projects LIMIT 1")
    suspend fun getProjectOnce(): ProjectEntity?
    @Query("SELECT * FROM construction_phases ORDER BY id")
    fun observePhases(): Flow<List<ConstructionPhaseEntity>>

    @Query("SELECT * FROM contractors ORDER BY company")
    fun observeContractors(): Flow<List<ContractorEntity>>

    @Query("SELECT * FROM expenses ORDER BY date DESC")
    fun observeExpenses(): Flow<List<ExpenseEntity>>

    @Query("SELECT * FROM documents ORDER BY id DESC")
    fun observeDocuments(): Flow<List<DocumentEntity>>

    @Insert(onConflict = OnConflictStrategy.IGNORE)
    suspend fun insertProject(project: ProjectEntity): Long
    @Insert(onConflict = OnConflictStrategy.IGNORE)
    suspend fun insertPhase(phase: ConstructionPhaseEntity): Long
    @Update
    suspend fun updatePhase(phase: ConstructionPhaseEntity)
    @Query("SELECT * FROM construction_phases WHERE projectId = :projectId AND name = :name LIMIT 1")
    suspend fun findPhaseByName(projectId: Long, name: String): ConstructionPhaseEntity?
    @Insert(onConflict = OnConflictStrategy.IGNORE)
    suspend fun insertContractor(contractor: ContractorEntity): Long
    @Update
    suspend fun updateContractor(contractor: ContractorEntity)
    @Query("SELECT * FROM contractors WHERE company = :company LIMIT 1")
    suspend fun findContractorByCompany(company: String): ContractorEntity?
    @Insert(onConflict = OnConflictStrategy.REPLACE)
    suspend fun insertExpense(expense: ExpenseEntity): Long
    @Insert(onConflict = OnConflictStrategy.REPLACE)
    suspend fun insertDocument(document: DocumentEntity): Long
    @Delete
    suspend fun deleteContractor(contractor: ContractorEntity)

    @Query("UPDATE construction_phases SET progress = :progress, status = :status WHERE id = :phaseId")
    suspend fun updatePhaseProgress(phaseId: Long, progress: Int, status: String)


    @Transaction
    suspend fun upsertPhaseByName(phase: ConstructionPhaseEntity): Long {
        val existing = findPhaseByName(phase.projectId, phase.name)
        return if (existing == null) {
            insertPhase(phase)
        } else {
            updatePhase(phase.copy(id = existing.id))
            existing.id
        }
    }


    @Transaction
    suspend fun upsertContractorByCompany(contractor: ContractorEntity): Long {
        val existing = findContractorByCompany(contractor.company)
        return if (existing == null) {
            insertContractor(contractor)
        } else {
            updateContractor(contractor.copy(id = existing.id))
            existing.id
        }
    }
}

@Database(
    entities = [ProjectEntity::class, ConstructionPhaseEntity::class, ContractorEntity::class, ExpenseEntity::class, DocumentEntity::class],
    version = 1,
    exportSchema = true
)
abstract class ConstructionDatabase : RoomDatabase() {
    abstract fun dao(): ConstructionDao


    companion object {
        @Volatile private var INSTANCE: ConstructionDatabase? = null


        fun get(context: Context): ConstructionDatabase = INSTANCE ?: synchronized(this) {
            INSTANCE ?: Room.databaseBuilder(context.applicationContext, ConstructionDatabase::class.java, "construction.db")
                .fallbackToDestructiveMigration(false)
                .build()
                .also { INSTANCE = it }
        }
    }
}



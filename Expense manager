data class UiState(
    val project: ProjectEntity? = null,
    val phases: List<ConstructionPhaseEntity> = emptyList(),
    val contractors: List<ContractorEntity> = emptyList(),
    val expenses: List<ExpenseEntity> = emptyList(),
    val documents: List<DocumentEntity> = emptyList(),
    val analytics: DashboardAnalytics = DashboardAnalytics()
)

class ConstructionViewModel(application: Application) : AndroidViewModel(application) {
    private val dao = ConstructionDatabase.get(application).dao()
    private val excelService = ConstructionExcelService(dao)

    val uiState: StateFlow<UiState> = combine(
        dao.observeProject(),
        dao.observePhases(),
        dao.observeContractors(),
        dao.observeExpenses(),
        dao.observeDocuments()
    ) { project, phases, contractors, expenses, documents ->
        UiState(project, phases, contractors, expenses, documents, calculateAnalytics(project, phases, expenses))
    }.stateIn(viewModelScope, SharingStarted.WhileSubscribed(5000), UiState())

    init { seedDatabaseOnce() }
    private fun seedDatabaseOnce() = viewModelScope.launch(Dispatchers.IO) {
        if (dao.getProjectOnce() != null) return@launch
        val projectId = dao.insertProject(ProjectEntity(name = "Romania House Construction", location = "Romania"))
        val defaultPhases = listOf(
            "Land Purchase", "Design & Architecture", "Building Permit", "Excavation", "Foundation", "Structure", "Roofing", "Electrical", "Plumbing", "HVAC", "Windows & Doors", "Interior Finishes", "Exterior Facade", "Landscaping", "Final Inspection"
        )
        val budgets = listOf(15000.0, 4000.0, 1500.0, 3000.0, 12000.0, 30000.0, 10000.0, 6000.0, 5000.0, 8000.0, 7000.0, 15000.0, 5000.0, 3000.0, 500.0)
        defaultPhases.forEachIndexed { index, name ->
            dao.insertPhase(ConstructionPhaseEntity(projectId = projectId, name = name, plannedCost = budgets[index], actualCost = 0.0, progress = 0, startDate = "", endDate = "", status = "Not Started"))
        }
        dao.insertContractor(ContractorEntity(company = "SC Construct SRL", contact = "Mihai Popescu", phone = "+40 700 000 001", email = "office@construct.ro", trade = "Structure"))
    }

    fun updateProgress(phaseId: Long, progress: Int) = viewModelScope.launch(Dispatchers.IO) {
        val safeProgress = progress.coerceIn(0, 100)
        val status = when {
            safeProgress >= 100 -> "Completed"
            safeProgress > 0 -> "In Progress"
            else -> "Not Started"
        }
        dao.updatePhaseProgress(phaseId, safeProgress, status)
    }

    fun addContractor(company: String, contact: String, phone: String, email: String, trade: String) = viewModelScope.launch(Dispatchers.IO) {
        if (company.isNotBlank()) dao.upsertContractorByCompany(ContractorEntity(company = company.trim(), contact = contact, phone = phone, email = email, trade = trade))
    }

    fun deleteContractor(contractor: ContractorEntity) = viewModelScope.launch(Dispatchers.IO) { dao.deleteContractor(contractor) }
    fun addExpense(phaseId: Long, contractorId: Long?, category: String, description: String, amount: Double, currency: String, vatIncluded: Boolean, date: String) = viewModelScope.launch(Dispatchers.IO) {
        if (amount > 0) dao.insertExpense(ExpenseEntity(phaseId = phaseId, contractorId = contractorId, category = category, description = description, amount = amount, currency = currency, vatIncluded = vatIncluded, date = date))
    }

    fun addDocument(phaseId: Long, expenseId: Long?, type: String, uri: Uri) = viewModelScope.launch(Dispatchers.IO) {
        dao.insertDocument(DocumentEntity(phaseId = phaseId, expenseId = expenseId, type = type, fileUri = uri.toString(), createdAt = System.currentTimeMillis().toString()))
    }

    fun importExcel(projectId: Long, inputStream: InputStream) = viewModelScope.launch { excelService.importWorkbook(projectId, inputStream) }

    fun exportExcel(outputStream: OutputStream, state: UiState) = viewModelScope.launch(Dispatchers.IO) {
        excelService.exportReports(state.project, state.phases, state.contractors, state.expenses, outputStream)
    }
}


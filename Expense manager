            analytics.warnings.forEach { Text("WARNING: $it", color = Color(0xFFB91C1C)) }
        }
    }
}

@Composable
fun PhaseCostChart(phases: List<ConstructionPhaseEntity>, expenses: List<ExpenseEntity>, project: ProjectEntity?) {
    val maxPlanned = phases.maxOfOrNull { it.plannedCost }?.coerceAtLeast(1.0) ?: 1.0
    Card(shape = RoundedCornerShape(20.dp)) {
        Column(Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(8.dp)) {
            Text("Budget vs Actual by Phase", fontWeight = FontWeight.Bold)
            phases.forEach { phase ->
                val actual = phaseActualCost(phase, expenses)
                Text("${phase.name}: ${formatMoney(actual, project)} / ${formatMoney(phase.plannedCost, project)}")
                Box(Modifier.fillMaxWidth().height(14.dp).background(Color(0xFFE2E8F0), RoundedCornerShape(10.dp))) {
                    Box(
                        Modifier.fillMaxHeight()
                            .fillMaxWidth((actual / maxPlanned).coerceIn(0.03, 1.0).toFloat())
                            .background(if (actual > phase.plannedCost) Color(0xFFEF4444) else Color(0xFF3B82F6), RoundedCornerShape(10.dp))
                    )
                }
            }
        }
    }
}


@Composable
fun PhaseProgressList(phases: List<ConstructionPhaseEntity>, expenses: List<ExpenseEntity>, project: ProjectEntity?, onProgress: (Long, Int) -> Unit) {
    Card(shape = RoundedCornerShape(20.dp)) {
        Column(Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(12.dp)) {
            Text("Construction Progress Per Phase", fontWeight = FontWeight.Bold)
            phases.forEach { phase ->
                val actual = phaseActualCost(phase, expenses)
                Column {
                    Row(Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) {
                        Text(phase.name, fontWeight = FontWeight.SemiBold)
                        Text(phase.status)
                    }
                    Slider(value = phase.progress.toFloat(), onValueChange = { onProgress(phase.id, it.roundToInt()) }, valueRange = 0f..100f)
                    Text("Budget variance: ${formatMoney(phase.plannedCost - actual, project)}")
                }
            }
        }
    }
}

@Composable
fun GanttChart(phases: List<ConstructionPhaseEntity>) {
    Card(shape = RoundedCornerShape(20.dp)) {
        Column(Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(8.dp)) {
            Text("Gantt Chart Timeline", fontWeight = FontWeight.Bold)
            phases.forEach { phase ->
                Row(verticalAlignment = Alignment.CenterVertically) {
                    Text(phase.name, modifier = Modifier.width(140.dp))
                    Box(Modifier.weight(1f).height(18.dp).background(Color(0xFFE2E8F0), RoundedCornerShape(20.dp))) {
                        Box(Modifier.fillMaxHeight().fillMaxWidth((phase.progress.coerceAtLeast(3)) / 100f).background(Color(0xFF6366F1), RoundedCornerShape(20.dp)))
                    }
                }
            }
        }
    }
}

@Composable
fun ContractorCrud(contractors: List<ContractorEntity>, onAdd: (String, String, String, String, String) -> Unit, onDelete: (ContractorEntity) -> Unit) {
    var company by remember { mutableStateOf("") }
    var contact by remember { mutableStateOf("") }
    var phone by remember { mutableStateOf("") }
    var email by remember { mutableStateOf("") }
    var trade by remember { mutableStateOf("") }

    Card(shape = RoundedCornerShape(20.dp)) {
        Column(Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(8.dp)) {
            Text("Contractor Database CRUD", fontWeight = FontWeight.Bold)
            OutlinedTextField(company, { company = it }, label = { Text("Company") }, modifier = Modifier.fillMaxWidth())
            OutlinedTextField(contact, { contact = it }, label = { Text("Contact") }, modifier = Modifier.fillMaxWidth())
            OutlinedTextField(phone, { phone = it }, label = { Text("Phone") }, modifier = Modifier.fillMaxWidth())
            OutlinedTextField(email, { email = it }, label = { Text("Email") }, modifier = Modifier.fillMaxWidth())
            OutlinedTextField(trade, { trade = it }, label = { Text("Trade") }, modifier = Modifier.fillMaxWidth())
            Button(onClick = { onAdd(company, contact, phone, email, trade); company = ""; contact = ""; phone = ""; email = ""; trade = "" }) { Text("Add Contractor") }
            contractors.forEach { contractor ->
                Row(Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) {
                    Text("${contractor.company} - ${contractor.trade}")
                    TextButton(onClick = { onDelete(contractor) }) { Text("Delete") }
                }
            }
        }
    }
}

@Composable
fun ExpenseEntry(phases: List<ConstructionPhaseEntity>, contractors: List<ContractorEntity>, onAdd: (Long, Long?, String, String, Double, String, Boolean, String) -> Unit) {
    var amount by remember { mutableStateOf("") }
    var description by remember { mutableStateOf("") }
    val phaseId = phases.firstOrNull()?.id ?: 1L
    val contractorId = contractors.firstOrNull()?.id

    Card(shape = RoundedCornerShape(20.dp)) {
        Column(Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(8.dp)) {
            Text("Expense Entry", fontWeight = FontWeight.Bold)
            OutlinedTextField(description, { description = it }, label = { Text("Description") }, modifier = Modifier.fillMaxWidth())
            OutlinedTextField(amount, { amount = it }, label = { Text("Amount") }, modifier = Modifier.fillMaxWidth())
            Button(onClick = { onAdd(phaseId, contractorId, "Materials", description, amount.toDoubleOrNull() ?: 0.0, "EUR", true, "2026-07-09") }) {
                Text("Save Expense")
            }
        }
    }
}

